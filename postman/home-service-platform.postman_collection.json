    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Checkout Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.data) {",
                  "  if (response.data.paymentId) {",
                  "    pm.collectionVariables.set('paymentId', response.data.paymentId);",
                  "  }",
                  "  if (response.data.checkoutUrl) {",
                  "    pm.collectionVariables.set('checkoutUrl', response.data.checkoutUrl);",
                  "  }",
                  "  if (response.data.sessionId) {",
                  "    pm.collectionVariables.set('checkoutSessionId', response.data.sessionId);",
                  "  }",
                  "  if (response.data.paymentIntentId) {",
                  "    pm.collectionVariables.set('stripePaymentIntentId', response.data.paymentIntentId);",
                  "  }",
                  "  if (response.data.bookingId) {",
                  "    pm.collectionVariables.set('bookingId', response.data.bookingId);",
                  "  }",
                  "}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/create"
          }
        },
        {
          "name": "Verify Checkout Session",
          "description": "Run this after completing payment from checkoutUrl if webhook is not running locally.",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/payments/verify-session?sessionId={{checkoutSessionId}}"
          }
        },
        {
          "name": "Stripe Webhook (local test)",
          "description": "Use this for local Stripe webhook testing. The paymentId and checkoutSessionId are populated automatically after Create Checkout Session. For real Stripe events, replace the signature header with a real Stripe signature generated from the raw event payload.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "stripe-signature",
                "value": "replace-with-real-stripe-signature",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook\",\n  \"object\": \"event\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"{{checkoutSessionId}}\",\n      \"object\": \"checkout.session\",\n      \"payment_intent\": \"{{stripePaymentIntentId}}\",\n      \"metadata\": {\n        \"bookingId\": \"{{bookingId}}\",\n        \"paymentId\": \"{{paymentId}}\"\n      }\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/api/payments/webhook"
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
